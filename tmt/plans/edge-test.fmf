summary: Edge test plan
discover:
  how: fmf
  test: edge-test
execute:
  how: tmt
provision:
  hardware:
    virtualization:
      is-supported: true
    cpu:
      processors: ">= 4"
    memory: ">= 16 GB"
    disk:
      - size: ">= 60 GB"

/edge-x86-commit:
  summary: Test OSTree commit deployed via kickstart
  description: |
    Image type: edge-commit (OSTree repository tarball)
    Deployment method: Network boot (PXE) with kickstart, OSTree commit served via HTTP
    Use case: Developer/admin who wants full control over installation using a custom kickstart.

    Test intent: Verify OSTree commit build, installation via kickstart on UEFI VM,
    rpm-ostree upgrade, and post-deployment system health.
  environment+:
    TEST_CASE: edge-commit

/edge-x86-installer:
  summary: Test OSTree commit deployed via ISO installer
  description: |
    Image type: edge-installer (bootable ISO with embedded OSTree commit)
    Deployment method: ISO boot and network boot (PXE) from extracted ISO content via HTTP (if supported)
    Use case: Edge sites with no network, factory floor deployment (USB stick), air-gapped environments.

    Test intent: Verify installation from ISO on BIOS and UEFI VM (offline),
    optionally via HTTP boot from extracted ISO content, rpm-ostree upgrade,
    and post-deployment system health.
  environment+:
    TEST_CASE: edge-installer

/edge-x86-raw-image:
  summary: Test raw disk image deployed via VM import
  description: |
    Image type: edge-raw-image (raw disk image, converted to qcow2)
    Deployment method: VM disk image import
    Use case: Quick VM-based deployment without installer — boot directly from a pre-built disk image.

    Test intent: Verify raw disk image build and VM disk image import on BIOS and UEFI VM
    (Fedora UEFI only), rpm-ostree rebase on BIOS VM, rpm-ostree upgrade
    on UEFI VM, and post-deployment system health.
  environment+:
    TEST_CASE: edge-raw-image

/edge-x86-simplified-installer:
  summary: Test OSTree commit deployed via simplified ISO installer
  description: |
    Image type: edge-simplified-installer (bootable ISO with embedded OSTree commit)
    Deployment method: ISO boot and HTTP boot
    Use case: Automated zero-touch onboarding with FDO using separated servers, or installation without FDO.

    Test intent: Verify simplified installer via ISO boot and HTTP boot
    on UEFI VM, installation without FDO, and with FDO using separated servers,
    three FDO authentication methods (insecure key, key hash, root certs), and TPM 2.0
    disk encryption, rpm-ostree rebase and upgrade, and post-deployment
    system health.
  environment+:
    TEST_CASE: edge-simplified-installer
  adjust+:
    - when: arch != x86_64
      enabled: false
    - when: distro == fedora
      enabled: false

/edge-x86-fdo-aio:
  summary: Test FDO onboarding with all-in-one server
  description: |
    Image type: edge-simplified-installer (bootable ISO with embedded OSTree commit)
    Deployment method: ISO boot and HTTP boot
    Use case: Automated zero-touch onboarding with FDO using all-in-one server.

    Test intent: Verify FDO onboarding with all-in-one server, three FDO authentication
    methods (insecure key, key hash, root certs), and TPM 2.0 disk encryption
    via ISO boot and HTTP boot on UEFI VM, rpm-ostree rebase and upgrade,
    and post-deployment system health.
  environment+:
    TEST_CASE: edge-fdo-aio
  adjust+:
    - when: arch != x86_64
      enabled: false
    - when: distro == fedora
      enabled: false
    - when: distro == cs-9
      enabled: false
    - when: distro == rhel-8-10
      enabled: false
    - when: distro == rhel-9-4
      enabled: false
    - when: distro == rhel-9-5
      enabled: false
    - when: distro == rhel-9-6
      enabled: false

/edge-x86-fdo-db:
  summary: Test FDO onboarding with database-backed servers
  description: |
    Image type: edge-simplified-installer (bootable ISO with embedded OSTree commit)
    Deployment method: ISO boot
    Use case: Automated zero-touch onboarding with FDO using database-backed servers (SQLite or PostgreSQL).

    Test intent: Verify FDO onboarding with database-backed servers, key hash
    authentication, and TPM 2.0 disk encryption via ISO boot on UEFI VM,
    and post-deployment system health.
  environment+:
    TEST_CASE: edge-fdo-db
  adjust+:
    - when: arch != x86_64
      enabled: false
    - when: distro == fedora
      enabled: false
    - when: distro == cs-9
      enabled: false
    - when: distro == rhel-8-10
      enabled: false
    - when: distro == rhel-9-4
      enabled: false
    - when: distro == rhel-9-5
      enabled: false
    - when: distro == rhel-9-6
      enabled: false

/edge-x86-ignition:
  summary: Test Ignition provisioning on simplified installer ISO and raw disk image
  description: |
    Image type: edge-simplified-installer (bootable ISO with embedded OSTree commit) and edge-raw-image
    (raw disk image, converted to qcow2)
    Deployment method: ISO boot and VM disk image import
    Use case: Automated firstboot provisioning with Ignition (embedded and firstboot).

    Test intent: Verify Ignition provisioning with embedded and firstboot config
    on simplified installer and raw disk image via ISO boot and VM disk image import
    on UEFI VM, rpm-ostree upgrade, and post-deployment system health.
  environment+:
    TEST_CASE: edge-ignition
  adjust+:
    - when: arch != x86_64
      enabled: false
    - when: distro == fedora
      enabled: false
    - when: distro == rhel-8-10
      enabled: false

/edge-x86-pulp:
  summary: Test OSTree commit distributed via Pulp server
  description: |
    Image type: edge-commit (OSTree repository tarball)
    Deployment method: ISO boot with kickstart
    Use case: Content distribution — OSTree commit uploaded to and served from Pulp server.

    Test intent: Verify OSTree commit upload to and pull from Pulp,
    installation via kickstart on BIOS VM, and post-deployment
    system health.
  environment+:
    TEST_CASE: edge-pulp
  adjust+:
    - when: arch != x86_64
      enabled: false
    - when: distro == fedora
      enabled: false
    - when: distro == cs-9
      enabled: false
    - when: distro == rhel-8-10
      enabled: false
    - when: distro == rhel-9-4
      enabled: false
    - when: distro == rhel-9-5
      enabled: false
    - when: distro == rhel-9-6
      enabled: false

/edge-x86-vsphere:
  summary: Test VMDK image deployed to vSphere
  description: |
    Image type: edge-vsphere (VMDK image)
    Deployment method: vSphere VM deployment with Ignition (firstboot)
    Use case: Edge system as vSphere VM, provisioned via Ignition (firstboot).

    Test intent: Verify VMDK image build with Ignition firstboot, upload to vSphere
    datastore as boot disk, UEFI VM creation and boot, rpm-ostree upgrade,
    and post-deployment system health.
  environment+:
    TEST_CASE: edge-vsphere
  adjust+:
    - when: arch != x86_64
      enabled: false
    - when: distro == fedora
      enabled: false
    - when: distro == cs-9
      enabled: false
    - when: distro == rhel-8-10
      enabled: false

/edge-x86-ami-image:
  summary: Test AMI deployed to AWS EC2
  description: |
    Image type: edge-ami (raw disk image for AWS)
    Deployment method: AWS EC2 instance deployment with Ignition (firstboot)
    Use case: Cloud deployment of edge system on AWS.

    Test intent: Verify raw disk image for AWS build with Ignition firstboot, upload
    to AWS S3 bucket and registration as AMI, EC2 instance deployment,
    rpm-ostree upgrade, and post-deployment system health.
  environment+:
    TEST_CASE: edge-ami-image
  adjust+:
    - when: distro == fedora
      enabled: false
    - when: distro == rhel-8-10
      enabled: false

/edge-x86-8to9:
  summary: Test OSTree-based upgrade from RHEL 8 to RHEL 9 or CentOS Stream 8 to CentOS Stream 9
  description: |
    Image type: edge-container (OCI container with OSTree repository)
    Deployment method: Network boot with kickstart
    Use case: Upgrade from RHEL 8 to RHEL 9 or CentOS Stream 8 to CentOS Stream 9.

    Test intent: Verify RHEL 8 or CentOS Stream 8 edge-container installation
    via kickstart on BIOS and UEFI VM, rpm-ostree rebase from version 8 to
    version 9, and post-deployment system health.
  environment+:
    TEST_CASE: edge-8to9
  adjust+:
    - when: distro == fedora
      enabled: false
    - when: distro == cs-9
      enabled: false
    - when: distro == rhel-8-10
      enabled: false

/edge-x86-9to9:
  summary: Test OSTree-based upgrade within RHEL 9
  description: |
    Image type: edge-container (OCI container with OSTree repository)
    Deployment method: Network boot with kickstart
    Use case: Upgrade within RHEL 9 (e.g., 9.4 to 9.5).

    Test intent: Verify RHEL 9.x edge-container installation via kickstart on BIOS and UEFI VM,
    rpm-ostree rebase on BIOS VM, rpm-ostree upgrade on UEFI VM, and post-deployment system health.
  environment+:
    TEST_CASE: edge-9to9
  adjust+:
    - when: distro == fedora
      enabled: false
    - when: distro == cs-9
      enabled: false
    - when: distro == rhel-8-10
      enabled: false

/edge-arm-ami-image:
  summary: Test AMI deployed to AWS EC2
  description: |
    Image type: edge-ami (raw disk image for AWS)
    Deployment method: AWS EC2 instance deployment with Ignition (firstboot)
    Use case: Cloud deployment of edge system on AWS.

    Test intent: Verify raw disk image for AWS build with Ignition firstboot, upload
    to AWS S3 bucket and registration as AMI, EC2 instance deployment,
    rpm-ostree upgrade, and post-deployment system health.
  environment+:
    TEST_CASE: edge-ami-image
  adjust+:
    - when: distro == fedora
      enabled: false

/edge-fdo-container:
  summary: Test FDO onboarding with containerized servers
  description: |
    Image type: edge-simplified-installer (bootable ISO with embedded OSTree commit)
    Deployment method: ISO boot
    Use case: Automated zero-touch onboarding with FDO using containerized servers.

    Test intent: Verify FDO onboarding with containerized servers and three FDO authentication methods
    (insecure key, key hash, root certs) via ISO boot on UEFI VM, and post-deployment system health.
  environment+:
    TEST_CASE: edge-fdo-container
